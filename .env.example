# Required
OPENAI_API_KEY=sk-...
APP_MODE=mock

# Optional — enables web search route
TAVILY_API_KEY=tvly-...

# Qdrant (make setup)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=certilab-rag

# MySQL (make setup — credentials match docker-compose.yml)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=certilab_test
DB_USERNAME=certilab
DB_PASSWORD=certilab

# S3 (optional — only needed for PDF ingestion from AWS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=

# Models
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.0

# Observability (optional)
PHOENIX_ENABLED=false
